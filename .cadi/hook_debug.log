d in keyring.\",\n+            settings,\n+            code=\"NOT_FOUND\",\n+            exit_code=ExitCode.NOT_FOUND,\n+        )\n+    except KeyringError as exc:\n+        emit_error(\n+            f\"Keyring error: {exc}\",\n+            settings,\n+            code=\"EXTERNAL_FAILURE\",\n+            exit_code=ExitCode.EXTERNAL_FAILURE,\n+        )\n+\n+    emit_success(\n+        {\"cleared\": True, \"location\": \"keyring\"},\n+        settings,\n+        text=\"Removed OpenRouter API key from system keyring.\",\n+    )\n+\n+\n if __name__ == \"__main__\":\n     app()","stderr":"","interrupted":false,"isImage":false},"tool_use_id":"toolu_01AG35Ab2Cui8TJT8vzmWX6G"}
