ct)\n    ctx.obj = OutputSettings(format=format, quiet=quiet)\n    init_db()\n\n\nif __name__ == \"__main__\":\n    app()\n","numLines":73,"startLine":1,"totalLines":73}},"tool_use_id":"toolu_01TDjwW4cFpYZnC2NsKZkHaM"}
